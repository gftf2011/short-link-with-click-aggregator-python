# --- postgres ---
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=shortlink_dev
POSTGRES_PORT=5432
# Host-side tools (alembic, scripts) use the published port; keep in sync if you change user/db/port above.
DATABASE_URL=postgresql+asyncpg://dev:dev@127.0.0.1:5432/shortlink_dev

# --- redis_cache ---
REDIS_CACHE_MASTER_PASSWORD=cache_master_dev
REDIS_CACHE_MAXMEMORY=128mb
REDIS_CACHE_APP_USERNAME=shortlink_cache
REDIS_CACHE_APP_PASSWORD=cache_dev_secret
REDIS_CACHE_PUBLISH_PORT=6379

# --- redis_codes ---
REDIS_CODES_MASTER_PASSWORD=codes_master_dev
REDIS_CODES_MAXMEMORY=128mb
REDIS_CODES_IO_THREADS=2
REDIS_CODES_APP_USERNAME=shortlink_codes
REDIS_CODES_APP_PASSWORD=codes_dev_secret
REDIS_CODES_PUBLISH_PORT=6380

# --- redis_clicks ---
REDIS_CLICKS_MASTER_PASSWORD=clicks_master_dev
REDIS_CLICKS_MAXMEMORY=128mb
REDIS_CLICKS_APP_USERNAME=shortlink_clicks
REDIS_CLICKS_APP_PASSWORD=clicks_dev_secret
REDIS_CLICKS_PUBLISH_PORT=6381

# --- api (host port only; in-stack hostnames/ports are fixed in compose) ---
API_PORT=8000

# --- proxy ---
PROXY_PORT=8080

# --- batch ---
MAX_SHORTLINK_CODES=17000001
SHORTLINK_CODES_BATCH_SIZE=4000
